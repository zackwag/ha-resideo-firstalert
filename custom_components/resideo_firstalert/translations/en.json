{
  "options": {
    "step": {
      "init": {
        "title": "Configure First Alert by Resideo",
        "menu_options": {
          "settings": "Settings",
          "update_token": "Update refresh token"
        }
      },
      "settings": {
        "title": "Settings",
        "data": {
          "scan_interval": "Update interval (seconds)"
