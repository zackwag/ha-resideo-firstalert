        "data_description": {
          "scan_interval": "How often to poll the Resideo API for updates (5-3600 seconds)"
        }
      },
      "update_token": {
        "title": "Update Refresh Token",
        "description": "Enter a new refresh token if your current one has expired.",
        "data": {
          "refresh_token": "Refresh Token"
        }
      }
    }
  },
  "config": {
    "step": {
      "user": {
        "title": "Connect to First Alert by Resideo",
        "description": "Choose how you want to authenticate with your Resideo account.\n\nSee the [documentation]({docs_url}) for more information.",
        "menu_options": {
          "oauth": "Login with Resideo (OAuth)",
          "manual": "Enter refresh token manually"
        }
      },
      "pick_implementation": {
        "title": "Pick Authentication Method"
      },
      "oauth": {
        "title": "Login with Resideo"
      },
      "manual": {
        "title": "Manual Token Entry",
        "description": "Enter your refresh token to connect your First Alert smoke detectors.\n\nSee the [documentation]({docs_url}) for instructions on how to obtain your refresh token.",
        "data": {
          "refresh_token": "Refresh Token"
        },
        "data_description": {
          "refresh_token": "The refresh token obtained from the Resideo API"
        }
      },
      "reauth_confirm": {
        "title": "Reauthenticate",
        "description": "Your authentication has expired. Please choose how to reauthenticate.",
        "menu_options": {
          "reauth_oauth": "Login with Resideo (OAuth)",
          "reauth_manual": "Enter refresh token manually"
        }
      },
      "reauth_oauth": {
        "title": "Reauthenticate with Resideo"
      },
      "reauth_manual": {
        "title": "Reauthenticate with Token",
        "description": "Enter a new refresh token to restore your connection.",
        "data": {
          "refresh_token": "Refresh Token"
        }
      }
    },
    "error": {
      "invalid_auth": "Invalid authentication - please check your refresh token",
      "cannot_connect": "Unable to connect to Resideo API",
      "unknown": "An unknown error occurred"
    },
    "abort": {
      "already_configured": "This account is already configured",
      "no_refresh_token": "No refresh token received from OAuth",
      "oauth_error": "Error verifying OAuth token",
      "reauth_successful": "Reauthentication successful"
    }
  },
  "application_credentials": {
    "description": "Follow the [instructions]({more_info_url}) to configure Resideo OAuth credentials.\n\nNote: OAuth requires the Resideo client ID. You can use the built-in client ID or provide your own.",
